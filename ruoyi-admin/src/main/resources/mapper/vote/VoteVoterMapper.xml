<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vote.mapper.VoteVoterMapper">

    <resultMap type="VoteVoter" id="VoteVoterResult">
        <id     property="voterId"     column="voter_id"    />
        <result property="activityId"  column="activity_id" />
        <result property="voterName"   column="voter_name"  />
        <result property="clientId"    column="client_id"   />
        <result property="ip"          column="ip"          />
        <result property="votesUsed"   column="votes_used"  />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <sql id="selectVoteVoterVo">
        select voter_id, activity_id, voter_name, client_id, ip, votes_used, create_time
        from vote_voter
    </sql>

    <select id="selectVoteVoterList" parameterType="VoteVoter" resultMap="VoteVoterResult">
        <include refid="selectVoteVoterVo"/>
        <where>
            <if test="activityId != null"> and activity_id = #{activityId}</if>
            <if test="voterName != null and voterName != ''"> and voter_name like concat('%', #{voterName}, '%')</if>
        </where>
        order by voter_id desc
    </select>

    <select id="selectVoteVoterById" parameterType="Long" resultMap="VoteVoterResult">
        <include refid="selectVoteVoterVo"/>
        where voter_id = #{voterId}
    </select>

    <insert id="insertVoteVoter" parameterType="VoteVoter" useGeneratedKeys="true" keyProperty="voterId">
        insert into vote_voter (
            activity_id, voter_name, client_id, ip, votes_used, create_time
        ) values (
            #{activityId}, #{voterName}, #{clientId}, #{ip}, #{votesUsed}, sysdate()
        )
    </insert>

    <select id="countByClient" resultType="int">
        select count(1) from vote_voter
        where activity_id = #{activityId} and client_id = #{clientId} and client_id != ''
    </select>

    <select id="countByActivityId" parameterType="Long" resultType="int">
        select count(1) from vote_voter where activity_id = #{activityId}
    </select>

    <delete id="deleteVoteVoterByActivityId" parameterType="Long">
        delete from vote_voter where activity_id = #{activityId}
    </delete>

</mapper>
