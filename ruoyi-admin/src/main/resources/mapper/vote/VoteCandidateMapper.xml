<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vote.mapper.VoteCandidateMapper">

    <resultMap type="VoteCandidate" id="VoteCandidateResult">
        <id     property="candidateId"  column="candidate_id" />
        <result property="activityId"   column="activity_id"  />
        <result property="name"         column="name"         />
        <result property="no"           column="no"           />
        <result property="avatar"       column="avatar"       />
        <result property="description"  column="description"  />
        <result property="sort"         column="sort"         />
        <result property="status"       column="status"       />
        <result property="createBy"     column="create_by"    />
        <result property="createTime"   column="create_time"  />
        <result property="updateBy"     column="update_by"    />
        <result property="updateTime"   column="update_time"  />
        <result property="remark"       column="remark"       />
    </resultMap>

    <sql id="selectVoteCandidateVo">
        select candidate_id, activity_id, name, no, avatar, description, sort, status,
               create_by, create_time, update_by, update_time, remark
        from vote_candidate
    </sql>

    <select id="selectVoteCandidateList" parameterType="VoteCandidate" resultMap="VoteCandidateResult">
        <include refid="selectVoteCandidateVo"/>
        <where>
            <if test="activityId != null"> and activity_id = #{activityId}</if>
            <if test="name != null and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort asc, candidate_id asc
    </select>

    <select id="selectVoteCandidateById" parameterType="Long" resultMap="VoteCandidateResult">
        <include refid="selectVoteCandidateVo"/>
        where candidate_id = #{candidateId}
    </select>

    <insert id="insertVoteCandidate" parameterType="VoteCandidate" useGeneratedKeys="true" keyProperty="candidateId">
        insert into vote_candidate (
            activity_id, name, no, avatar, description, sort, status, create_by, create_time, remark
        ) values (
            #{activityId}, #{name}, #{no}, #{avatar}, #{description}, #{sort}, #{status}, #{createBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updateVoteCandidate" parameterType="VoteCandidate">
        update vote_candidate
        <set>
            <if test="activityId != null">activity_id = #{activityId},</if>
            <if test="name != null">name = #{name},</if>
            <if test="no != null">no = #{no},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where candidate_id = #{candidateId}
    </update>

    <delete id="deleteVoteCandidateById" parameterType="Long">
        delete from vote_candidate where candidate_id = #{candidateId}
    </delete>

    <delete id="deleteVoteCandidateByIds" parameterType="Long">
        delete from vote_candidate where candidate_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteVoteCandidateByActivityId" parameterType="Long">
        delete from vote_candidate where activity_id = #{activityId}
    </delete>

</mapper>
